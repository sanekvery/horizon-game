// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ПОЛЬЗОВАТЕЛИ И АВТОРИЗАЦИЯ
// ============================================

// Базовый пользователь (игрок или фасилитатор)
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  emailVerified   Boolean   @default(false) @map("email_verified")
  verifyToken     String?   @map("verify_token")
  resetToken      String?   @map("reset_token")
  resetTokenExp   DateTime? @map("reset_token_exp")

  createdAt       DateTime  @default(now()) @map("created_at")
  lastLoginAt     DateTime? @map("last_login_at")

  // Профили (оба опциональные - один User может быть и игроком, и фасилитатором)
  playerProfile   PlayerProfile?

  // Сессии авторизации
  authSessions    AuthSession[]

  @@map("users")
}

// Сессии авторизации (для JWT refresh и управления устройствами)
model AuthSession {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  userAgent   String?  @map("user_agent")
  ipAddress   String?  @map("ip_address")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("auth_sessions")
}

// Профиль игрока (один на все роли)
model PlayerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  displayName     String   @map("display_name")
  avatar          String?  // URL или код аватара

  // Прогрессия (общая на все роли)
  totalXP         Int      @default(0) @map("total_xp")
  level           Int      @default(0)
  stats           Json     @default("{\"strength\":5,\"agility\":5,\"negotiation\":5,\"intellect\":5,\"charisma\":5,\"craft\":5,\"luck\":5,\"endurance\":5,\"leadership\":5,\"perception\":5}")
  availablePoints Int      @default(0) @map("available_points")

  // Достижения
  achievements    Json     @default("[]")

  // Статистика
  totalGames      Int      @default(0) @map("total_games")
  totalWins       Int      @default(0) @map("total_wins")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // История игр
  gameHistory     PlayerGameHistory[]

  // Связь с сессиями (когда игрок в активной игре)
  sessionPlayers  SessionPlayer[]

  @@map("player_profiles")
}

// История игр игрока
model PlayerGameHistory {
  id                    String        @id @default(uuid())
  playerProfileId       String        @map("player_profile_id")
  playerProfile         PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  sessionId             String        @map("session_id")
  session               GameSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  roleId                Int           @map("role_id")
  roleName              String        @map("role_name")

  xpEarned              Int           @default(0) @map("xp_earned")
  statsSnapshot         Json          @map("stats_snapshot") // Статы на момент игры

  // Результат
  teamWon               Boolean       @default(false) @map("team_won")
  personalScore         Int?          @map("personal_score")

  playedAt              DateTime      @default(now()) @map("played_at")
  duration              Int?          // Длительность в минутах

  // Достижения, полученные в этой игре
  achievementsUnlocked  Json          @default("[]") @map("achievements_unlocked")

  @@index([playerProfileId])
  @@index([sessionId])
  @@map("player_game_history")
}

// ============================================
// ФАСИЛИТАТОРЫ (существующая модель)
// ============================================

// Фасилитаторы (пользователи системы)
model Facilitator {
  id                    String         @id @default(uuid())
  email                 String         @unique
  passwordHash          String         @map("password_hash")
  name                  String?
  role                  FacilitatorRole @default(FACILITATOR)
  subscriptionType      SubscriptionType @default(FREE) @map("subscription_type")
  subscriptionExpiresAt DateTime?      @map("subscription_expires_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  sessions              GameSession[]
  characterProgress     CharacterProgress[]

  @@map("facilitators")
}

enum FacilitatorRole {
  FACILITATOR
  ADMIN
}

enum SubscriptionType {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// Игровые сессии
model GameSession {
  id                  String           @id @default(uuid())
  facilitatorId       String           @map("facilitator_id")
  facilitator         Facilitator      @relation(fields: [facilitatorId], references: [id])
  code                String           @unique @db.VarChar(8)
  name                String?
  status              SessionStatus    @default(SETUP)
  playerCount         Int              @map("player_count")
  settings            Json             @default("{}")
  state               Json             @default("{}")
  progressionEnabled  Boolean          @default(false) @map("progression_enabled")
  startedAt           DateTime?        @map("started_at")
  finishedAt          DateTime?        @map("finished_at")
  createdAt           DateTime         @default(now()) @map("created_at")

  players             SessionPlayer[]
  actionLogs          ActionLog[]
  gameEvents          GameEvent[]
  playerHistories     PlayerGameHistory[]

  @@index([facilitatorId])
  @@index([status])
  @@index([code])
  @@map("game_sessions")
}

enum SessionStatus {
  SETUP
  ACTIVE
  PAUSED
  FINISHED
}

// Участники сессий
model SessionPlayer {
  id                String         @id @default(uuid())
  sessionId         String         @map("session_id")
  session           GameSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  roleId            Int            @map("role_id")
  playerName        String?        @map("player_name")
  token             String         @unique @db.VarChar(16)
  stats             Json           @default("{\"strength\":5,\"agility\":5,\"negotiation\":5,\"intellect\":5,\"charisma\":5,\"craft\":5}")
  experienceGained  Int            @default(0) @map("experience_gained")
  isConnected       Boolean        @default(false) @map("is_connected")
  joinedAt          DateTime?      @map("joined_at")
  lastSeenAt        DateTime?      @map("last_seen_at")
  createdAt         DateTime       @default(now()) @map("created_at")

  // Связь с профилем игрока (опционально для гостей)
  playerProfileId   String?        @map("player_profile_id")
  playerProfile     PlayerProfile? @relation(fields: [playerProfileId], references: [id])

  actionLogs        ActionLog[]

  @@index([sessionId])
  @@index([token])
  @@index([playerProfileId])
  @@map("session_players")
}

// Лог действий
model ActionLog {
  id            String         @id @default(uuid())
  sessionId     String         @map("session_id")
  session       GameSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId      String?        @map("player_id")
  player        SessionPlayer? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  actorType     ActorType      @map("actor_type")
  actionType    String         @map("action_type") @db.VarChar(50)
  actionData    Json           @default("{}") @map("action_data")
  gameContext   Json           @default("{}") @map("game_context")
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])
  @@map("action_logs")
}

enum ActorType {
  PLAYER
  FACILITATOR
  SYSTEM
}

// События игры
model GameEvent {
  id              String       @id @default(uuid())
  sessionId       String       @map("session_id")
  session         GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType       String       @map("event_type") @db.VarChar(50)
  eventId         Int          @map("event_id")
  triggeredBy     String       @map("triggered_by") @db.VarChar(50)
  choiceMade      String?      @map("choice_made")
  effectsApplied  Json?        @map("effects_applied")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([sessionId])
  @@map("game_events")
}

// Прогресс персонажей (между играми)
model CharacterProgress {
  id                String       @id @default(uuid())
  facilitatorId     String       @map("facilitator_id")
  facilitator       Facilitator  @relation(fields: [facilitatorId], references: [id])
  playerIdentifier  String       @map("player_identifier") @db.VarChar(255)
  roleId            Int          @map("role_id")
  totalGames        Int          @default(0) @map("total_games")
  totalExperience   Int          @default(0) @map("total_experience")
  stats             Json         @default("{}")
  achievements      Json         @default("[]")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@unique([facilitatorId, playerIdentifier, roleId])
  @@map("character_progress")
}
